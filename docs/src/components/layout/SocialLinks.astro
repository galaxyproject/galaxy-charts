---

<div class={className}>
  {
    links.map((link) => (
      <a
        href={link.href}
        class="social-icon text-gray-400 hover:text-galaxy-gold"
        aria-label={link.label}
        target="_blank"
        rel="noopener"
      >
        <svg class={size} fill="currentColor" viewBox="0 0 24 24">
          <path d={ICONS[link.icon]} />
        </svg>
      </a>
    ))
  }
</div>

<style>
  .social-icon {
    transition:
      transform 0.2s ease,
      color 0.2s ease;
  }
  .social-icon:hover {
    transform: scale(1.15);
  }
</style>
