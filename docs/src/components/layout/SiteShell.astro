---
/**
 * SiteShell — page chrome (optional sidebar + main).
 *
 * Pure shell: no SiteConfig dependency. Takes already-resolved title /
 * description / favicon strings + a `sidebar` named slot. The explicit
 * `showSidebar` prop drives the main-content offset (we don't infer from
 * `Astro.slots.has` because conditionally-rendered slot content isn't always
 * detected reliably).
 */
import "../../styles/global.css";
import { STORAGE_KEY, DEFAULT_DARK } from "@/utils/theme";

// Tiny pre-paint boot script. Mirrors getInitialDark() in @/utils/theme; the
// values are template-stringified in so the script stays self-contained.
const themeBoot = `(function(){try{var s=localStorage.getItem(${JSON.stringify(STORAGE_KEY)});var d=s?s==="dark":${DEFAULT_DARK};if(d)document.documentElement.classList.add("dark");}catch(e){}})();`;

interface Props {
    /** Full document title — caller composes any "site name" suffix. */
    pageTitle: string;
    /** Meta description. */
    pageDescription: string;
    /** Resolved favicon URL (already prefixed with BASE_URL). */
    faviconHref?: string;
    /** Whether the caller is filling the `sidebar` slot. Default true. */
    showSidebar?: boolean;
}

const { pageTitle, pageDescription, faviconHref, showSidebar = true } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        {/* Pre-paint theme boot — see @/utils/theme. */}
        <script is:inline set:html={themeBoot} />
        {faviconHref && <link rel="icon" href={faviconHref} />}
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={pageDescription} />
        <title>{pageTitle}</title>
        <meta property="og:title" content={pageTitle} />
        <meta property="og:description" content={pageDescription} />
        <meta property="og:type" content="website" />
        <meta name="twitter:card" content="summary_large_image" />
    </head>
    <body class="min-h-screen text-foreground">
        <slot name="mobile-bar" />
        <slot name="sidebar" />

        <main
            class:list={[
                "min-h-screen overflow-x-clip flex flex-col",
                showSidebar && "lg:ml-sidebar",
                showSidebar && "pt-14 lg:pt-0",
            ]}>
            <slot />
        </main>
    </body>
</html>
