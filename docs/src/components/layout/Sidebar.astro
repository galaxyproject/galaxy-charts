---
/**
 * Desktop sidebar — content-agnostic.
 *   top:    BrandMark (linked to home)
 *   middle: navigation
 *   bottom: optional social links
 */
import type { NavConfig, SiteConfig, SocialLink } from "@/config/types";
import BrandMark from "./BrandMark.astro";
import SidebarNav from "./SidebarNav.vue";
import SocialLinks from "./SocialLinks.astro";
import ThemeToggle from "./ThemeToggle.vue";

interface Props {
    site: SiteConfig;
    nav: NavConfig;
    /** Optional bottom-of-sidebar social links. */
    social?: SocialLink[];
    /** Server-resolved current path (e.g. `Astro.url.pathname`). */
    currentPath: string;
}

const { site, nav, social = [], currentPath } = Astro.props;
---

<aside
    class="hidden lg:flex flex-col w-sidebar fixed left-0 top-0 h-screen overflow-y-auto z-40 bg-[var(--sidebar-bg)] text-[var(--sidebar-text)]">
    <div class="px-4 py-6 flex justify-center border-b border-[var(--sidebar-border)]">
        <BrandMark site={site} large />
    </div>

    <div class="flex-1 p-4 overflow-y-auto">
        <SidebarNav nav={nav} currentPath={currentPath} client:load />
    </div>

    <div class="p-4 border-t border-[var(--sidebar-border)] flex items-center justify-between gap-3">
        <SocialLinks links={social} />
        <ThemeToggle client:load />
    </div>
</aside>
