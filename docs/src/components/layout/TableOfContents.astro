---
import { visibleHeadings, hasToc, type Heading } from "@/utils/toc";

interface Props {
    headings: Heading[];
    /** Heading text shown above the list. */
    title?: string;
}

const { headings, title = "On this page" } = Astro.props;
const filtered = visibleHeadings(headings);
---

{
    hasToc(headings) && (
        <nav class="toc text-sm" aria-label="Table of Contents">
            <h2 class="text-xs font-semibold uppercase tracking-wider text-[var(--surface-muted)] mb-3">{title}</h2>
            <ul class="list-none p-0 m-0">
                {filtered.map((heading) => (
                    <li class={`toc-item toc-depth-${heading.depth}`}>
                        <a href={`#${heading.slug}`} class="toc-link">
                            {heading.text}
                        </a>
                    </li>
                ))}
            </ul>
        </nav>
    )
}

<style>
    /* TOC links share the sidebar's `--sidebar-*` palette so left-nav and
       right-nav stay visually consistent in both light and dark mode. */
    .toc-item {
        margin-bottom: 0.25rem;
    }
    .toc-depth-2 {
        padding-left: 0;
    }
    .toc-depth-3 {
        padding-left: 0.75rem;
    }
    .toc-depth-4 {
        padding-left: 1.5rem;
    }
    .toc-link {
        display: block;
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
        font-size: 0.875rem;
        line-height: 1.4;
        color: var(--sidebar-text-muted);
        text-decoration: none;
        transition:
            background-color 0.15s,
            color 0.15s;
    }
    .toc-link:hover {
        background-color: var(--sidebar-hover-bg);
        color: var(--sidebar-hover-text);
    }
    .toc-link.active {
        color: var(--sidebar-active-text);
        background-color: var(--sidebar-active-bg);
    }
</style>
