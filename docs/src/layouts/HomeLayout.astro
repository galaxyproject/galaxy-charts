---
/**
 * Landing page layout: full-bleed hero + features grid. No sidebar.
 * Driven by props — no hardcoded content.
 */
import BaseLayout from "./BaseLayout.astro";
import BrandMark from "@/components/layout/BrandMark.astro";
import { resolveHref } from "@/utils/url";
import { site } from "@/config/site";
import type { Feature, FeaturesHeader, HeroConfig } from "@/config/home";

interface Props {
    title: string;
    description?: string;
    hero: HeroConfig;
    features?: Feature[];
    featuresHeader?: FeaturesHeader;
}

const { title, description, hero, features = [], featuresHeader } = Astro.props;
---

<BaseLayout title={title} description={description} showSidebar={false} bare>
    <div class="home-banner relative overflow-hidden">
        <div class="bg-grid-dark absolute inset-0 pointer-events-none"></div>
        <slot name="hero-after" />

        {/* Same on-screen position as the sidebar's BrandMark on docs pages. */}
        {
            /* Wrapper offsets compensate for px-3 py-2 so the BrandMark inside
            lands at exactly (1.5rem, 1rem) — matching the sidebar's BrandMark. */
        }
        <div class="fixed top-2 left-8 z-20 bg-galaxy-dark rounded-lg px-3 py-2">
            <BrandMark site={site} />
        </div>

        <section class="relative z-10 px-4 sm:px-6 lg:px-8">
            <div
                class="max-w-5xl mx-auto my-16 sm:my-20 px-6 py-12 sm:py-16 text-left rounded-xl bg-galaxy-dark opacity-95 border border-white/10">
                {hero.name && <p class="text-3xl sm:text-5xl text-white font-bold tracking-tight mb-3">{hero.name}</p>}
                <h1 class="text-3xl sm:text-5xl font-bold text-galaxy-gold tracking-tight">{hero.text}</h1>
                {hero.tagline && <p class="mt-6 text-lg sm:text-xl text-white/80 max-w-2xl">{hero.tagline}</p>}
                {
                    hero.actions && hero.actions.length > 0 && (
                        <div class="mt-8 flex flex-wrap gap-3">
                            {hero.actions.map((action) => (
                                <a
                                    href={resolveHref(action.href)}
                                    class:list={[
                                        "inline-flex items-center px-7 py-3.5 rounded-md transition-colors",
                                        action.variant === "alt"
                                            ? "bg-white/10 text-white hover:bg-white/20 border border-white/20"
                                            : "bg-galaxy-gold text-galaxy-dark hover:bg-accent-hover font-semibold",
                                    ]}>
                                    {action.text}
                                </a>
                            ))}
                        </div>
                    )
                }
            </div>
        </section>

        {
            features.length > 0 && (
                <section class="relative z-10 px-4 sm:px-6 lg:px-8 pb-16 sm:pb-20">
                    <div class="max-w-5xl mx-auto">
                        {(featuresHeader?.title || featuresHeader?.tagline) && (
                            <header class="text-center mb-12">
                                {(featuresHeader.title || featuresHeader.emphasis) && (
                                    <h2 class="text-3xl sm:text-4xl font-bold text-white tracking-tight">
                                        {featuresHeader.title}
                                        {featuresHeader.emphasis && (
                                            <span class="italic font-medium"> {featuresHeader.emphasis}</span>
                                        )}
                                    </h2>
                                )}
                                {featuresHeader.tagline && (
                                    <p class="mt-3 text-white/70 text-lg max-w-2xl mx-auto">{featuresHeader.tagline}</p>
                                )}
                            </header>
                        )}
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                            {features.map((f) => (
                                <article class="feature-card">
                                    {f.iconPath && (
                                        <div class="feature-icon">
                                            <svg
                                                xmlns="http://www.w3.org/2000/svg"
                                                fill="none"
                                                viewBox="0 0 24 24"
                                                stroke="currentColor">
                                                <path
                                                    stroke-linecap="round"
                                                    stroke-linejoin="round"
                                                    stroke-width="2"
                                                    d={f.iconPath}
                                                />
                                            </svg>
                                        </div>
                                    )}
                                    <h3 class="text-lg font-semibold text-white mb-1">{f.title}</h3>
                                    {f.subtitle && <p class="text-galaxy-gold text-sm mb-3">{f.subtitle}</p>}
                                    <p class="text-white/70 text-sm leading-relaxed">{f.description}</p>
                                </article>
                            ))}
                        </div>
                    </div>
                </section>
            )
        }
    </div>
</BaseLayout>

<style>
    .feature-card {
        background: var(--color-galaxy-dark);
        border: 1px solid rgba(255, 255, 255, 0.1);
        border-radius: 0.5rem;
        padding: 1.5rem;
        opacity: 0.95;
    }

    .feature-icon {
        display: flex;
        align-items: center;
        justify-content: center;
        width: 2.5rem;
        height: 2.5rem;
        margin-bottom: 1rem;
        background: var(--color-galaxy-primary);
        border-radius: 0.375rem;
    }
    .feature-icon svg {
        width: 1.25rem;
        height: 1.25rem;
        color: var(--color-galaxy-gold);
    }
</style>
